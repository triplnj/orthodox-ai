generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String?
  passwordHash       String?
  emailVerified      DateTime?
  onboardingCompleted Boolean  @default(false)
  spiritualGoal       String?
  experienceLevel     String?
  dailyTime           String?
  plan               Plan     @default(FREE)
  stripeCustomerId   String?
  subscriptionStatus String?
  subscriptionId     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  messages           ChatMessage[]
  usageLogs          UsageLog[]
  journalEntries     JournalEntry[]
  sessions           Session[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@map("users")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  category  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chat_messages")
}

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
  @@map("usage_logs")
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  content   String
  aiSummary String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("journal_entries")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

